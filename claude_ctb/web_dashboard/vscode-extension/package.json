{
  "name": "claude-ctb-dashboard",
  "displayName": "Claude-CTB Dashboard",
  "description": "Monitor Claude Code sessions from VS Code",
  "version": "0.1.0",
  "publisher": "claude-ctb",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeCtb.openDashboard",
        "title": "Claude-CTB: Open Dashboard"
      },
      {
        "command": "claudeCtb.refreshSessions",
        "title": "Claude-CTB: Refresh Sessions"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-ctb",
          "title": "Claude-CTB",
          "icon": "$(terminal)"
        }
      ]
    },
    "views": {
      "claude-ctb": [
        {
          "id": "claudeCtbSessions",
          "name": "Sessions"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
