# CTB Dashboard — environment variables
# Copy to .env and fill in values

# --- Core ---
CTB_FOCUS_SECRET=your-focus-secret-here

# --- PI Review Gate (Phase 1B) ---
# HMAC secret for signed review deep-links (required; /review returns 403 if unset)
CTB_REVIEW_SECRET=change-me-to-a-long-random-string

# Directory for ticket-overlay.json, consumed-links.json, reviewers.yaml, overlay.lock
# Defaults to ~/.claude-ops
CTB_REVIEW_OVERLAY_DIR=~/.claude-ops

# Timeout (seconds) for acquiring overlay.lock
CTB_REVIEW_OVERLAY_LOCK_TIMEOUT=10

# Secret key for session cookies (auto-generated if unset; won't persist across restarts)
SESSION_SECRET_KEY=change-me-to-a-long-random-string

# --- Telegram Escalation ---
TELEGRAM_BOT_TOKEN=
